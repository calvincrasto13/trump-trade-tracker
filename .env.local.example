# Quiver Quantitative API — get free trial at api.quiverquant.com (promo: TWITTER)
QUIVER_API_KEY=your_quiver_api_key_here

# Supabase — create free project at supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# WhatsApp via OpenWA (self-hosted) OR Twilio sandbox
# Option A: OpenWA (free, self-hosted) — github.com/rmyndharis/OpenWA
OPENWA_URL=http://localhost:3000
OPENWA_TOKEN=your_openwa_token

# Option B: Twilio sandbox (free tier)
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Cron security — any random string
CRON_SECRET=your_secret_cron_token
